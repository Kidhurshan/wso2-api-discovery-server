# =============================================================================
# WSO2 API Discovery Server — config.toml
# =============================================================================
# Single config file. Same shape works for both VM (systemd) and K8s
# (Deployment + ConfigMap). Toggle [k8s] block at the bottom to switch.
#
# Secrets must come from environment variables via the ${VAR} or
# ${VAR:-default} substitution syntax. Never put real passwords here —
# they belong in /etc/ads/ads.env (VM) or a Kubernetes Secret (K8s).
# =============================================================================

[ads]
name      = "wso2-api-discovery-server"
version   = "1.0.0"
log_level = "info"   # debug | info | warn | error

[database]
host                    = "localhost"
port                    = 5432
name                    = "ads"
user                    = "ads"
password                = "${ADS_DB_PASSWORD}"
sslmode                 = "disable"   # disable | require | verify-ca | verify-full
max_open_conns          = 25
max_idle_conns          = 5
connect_timeout_seconds = 10

[deepflow]
enabled             = true
clickhouse_url      = "http://10.50.0.11:30617"
clickhouse_user     = "default"
clickhouse_password = "${DEEPFLOW_CH_PASSWORD:-}"
verify_ssl          = false
timeout_seconds     = 30

[apim]
publisher_url            = "https://apim.techmart.internal:9443"
service_account_username = "admin"
service_account_password = "${APIM_SVC_PASSWORD}"
verify_ssl               = false
timeout_seconds          = 30
introspect_url           = "https://localhost:9443/oauth2/introspect"
introspect_basic_auth    = "${APIM_INTROSPECT_BASIC_AUTH}"

# =============================================================================
# Phase 1 — traffic discovery (DeepFlow → ads_discovered_apis)
# =============================================================================

[discovery]
poll_interval_minutes     = 5
window_minutes            = 5
status_min                = 200
status_max                = 400
skip_internal             = false
min_observations          = 1
max_signatures_per_window = 10000

# Two-list noise filter:
#   path_patterns — substring (CONTAINS) match. Drops any path containing
#                   the entry, e.g. "/health" drops "/orders/1.0.0/health".
#   path_exact    — exact-equality match. Used for paths where contains
#                   would over-match, e.g. "/" only drops the literal root.
[discovery.noise_filter]
path_patterns = [
    "/health", "/healthz", "/ping", "/ready", "/readiness",
    "/liveness", "/actuator",
    "/agent.Synchronizer", "/grpc.health.v1.HealthService",
    "/controller.", "/tagrecorder.",
    "/metadata", "/machine", "/vmSettings", "/vmAgentLog",
    "/latest/meta-data", "/computeMetadata",
    "/apis/", "/api/v1/",
    "/favicon.ico", "/.well-known", "/swagger", "/openapi",
    "/robots.txt", "/.env",
]
path_exact       = ["/", "/version", "/metrics"]
excluded_ports   = []
excluded_domains = ["169.254.169.254"]

# Path normalization (segment-based).
#
# Algorithm: split path by '/', for each segment:
#   1. If any exclude_patterns regex matches → keep the segment as-is.
#   2. Else if any builtin_patterns or user_patterns regex matches → "{id}".
#   3. Else keep the segment.
#
# All patterns are anchored with ^...$ because they match a single segment.
# user_patterns is empty by default — operators add their own rules here
# without modifying the spec-defined builtin set.
[discovery.normalization]
version_pattern = "^v?[0-9]+\\.[0-9]+(\\.[0-9]+)?$"
builtin_patterns = [
    "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",  # UUID
    "^[0-9a-fA-F]{24,}$",                                                              # MongoDB ObjectID / hex hash
    "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",                                                    # ISO date
    "^[0-9]+$",                                                                        # numeric ID
    "^[A-Za-z0-9_-]{20,}={0,2}$",                                                      # base64-ish opaque token
    "^[A-Z]{2,5}-[A-Z0-9-]{3,}$",                                                      # SKU pattern
]
user_patterns = []
exclude_patterns = [
    "^v?[0-9]+\\.[0-9]+(\\.[0-9]+)?$",   # versions like 1.0.0, v2.1
    "^v[0-9]+$",                          # short versions like v1, v2
    "^api$",                              # literal "api" word
]

# =============================================================================
# Phase 2 — managed API sync (APIM Publisher → ads_managed_apis)
# =============================================================================

[managed]
poll_interval_minutes = 10
fetch_concurrency     = 5

# =============================================================================
# Phase 3 — comparison (ads_discovered_apis ↔ ads_managed_apis → ads_classifications)
# =============================================================================

[comparison]
freshness_threshold_multiplier = 3   # Phase 3 needs Phase 2 success within
                                     # 3 * managed.poll_interval

# =============================================================================
# BFF — REST surface APIM's admin v1 BFF reads
# =============================================================================

[bff]
listen_addr           = "0.0.0.0:8443"
tls_cert              = "/etc/ads/certs/server.crt"
tls_key               = "/etc/ads/certs/server.key"
verify_client_cert    = false   # bearer token auth, not mTLS
read_timeout_seconds  = 30
write_timeout_seconds = 30

[bff.token_cache]
ttl_seconds  = 30
max_entries  = 1000

[health]
listen_addr = "0.0.0.0:9090"   # separate port from BFF for K8s probes

# =============================================================================
# K8s — leader election when running multi-replica in Kubernetes.
# Leave enabled = false for VM / single-instance installs. Same file works
# for both deployment models.
# =============================================================================

[k8s]
enabled   = false
# namespace = "${POD_NAMESPACE}"   # populated by K8s downward API
# pod_name  = "${POD_NAME}"        # populated by K8s downward API

# =============================================================================
# Retention
# =============================================================================

[retention]
classifications_retention_days = 90
discovered_apis_retention_days = 30
