# config.toml.example — full ADS daemon configuration reference.
#
# Copy to /etc/ads/config.toml (or pass via --config) and override values for
# your environment. Every secret should come from an env var via the ${VAR}
# or ${VAR:-default} substitution syntax (see operations_guide.md §1.3).
#
# This file is the canonical reference for valid keys and their defaults.

[ads]
name      = "wso2-api-discovery-server"
version   = "1.0.0"
log_level = "info"   # debug | info | warn | error

[database]
host                    = "localhost"
port                    = 5432
name                    = "ads"
user                    = "ads"
password                = "${ADS_DB_PASSWORD}"
sslmode                 = "disable"   # disable | require | verify-ca | verify-full
max_open_conns          = 25
max_idle_conns          = 5
connect_timeout_seconds = 10

[deepflow]
enabled             = true
clickhouse_url      = "http://deepflow.techmart.internal:9000"
clickhouse_user     = "default"
clickhouse_password = "${DEEPFLOW_CH_PASSWORD:-}"
verify_ssl          = true
timeout_seconds     = 30

[apim]
publisher_url            = "https://apim.techmart.internal:9443"
service_account_username = "ads-service"
service_account_password = "${APIM_SVC_PASSWORD}"
verify_ssl               = true
timeout_seconds          = 30
introspect_url           = "https://apim.techmart.internal:9443/oauth2/introspect"
# Base64(client_id:client_secret) acquired via DCR; see Round 3 of the plan.
introspect_basic_auth    = "${APIM_INTROSPECT_BASIC_AUTH}"

# Phase 1 — Traffic discovery
[discovery]
poll_interval_minutes     = 5
window_minutes            = 5
status_min                = 200
status_max                = 400
skip_internal             = true   # flip to false to include internal traffic
min_observations          = 1
max_signatures_per_window = 10000

[discovery.noise_filter]
path_pattern = "^/(health|healthz|metrics|debug|favicon\\.ico|robots\\.txt|swagger|swagger-ui).*"
ports        = [9090, 6443, 10250, 10251, 10252, 2379, 2380]
domains      = ["kubernetes.default.svc", "kubernetes.default.svc.cluster.local"]

[discovery.normalization_rules_meta]
version = "v1"

# NOTE on regex syntax: Go's regexp package uses RE2, which does not support
# Perl-style lookahead `(?=...)`. The spec's documented patterns use
# `(?=/|$)` to match path-segment boundaries; the equivalent in RE2 is the
# word boundary `\b` (a zero-width assertion between a word char and a
# non-word char). All default rules ending in word chars (digits, hex,
# uppercase letters) are functionally equivalent under either form.

[[discovery.normalization_rules]]
name        = "uuid_v4"
pattern     = '/[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}\b'
placeholder = '/{id}'

[[discovery.normalization_rules]]
name        = "numeric_id"
pattern     = '/[0-9]+\b'
placeholder = '/{id}'

[[discovery.normalization_rules]]
name        = "mongo_objectid"
pattern     = '/[0-9a-f]{24}\b'
placeholder = '/{id}'

[[discovery.normalization_rules]]
name        = "iso_date"
pattern     = '/\d{4}-\d{2}-\d{2}\b'
placeholder = '/{id}'

[[discovery.normalization_rules]]
name        = "sku_pattern"
pattern     = '/[A-Z]{3,}(-[A-Z0-9]+)+\b'
placeholder = '/{id}'

[[discovery.normalization_rules]]
name        = "customer_id"
pattern     = '/CUST-[A-Z0-9]+\b'
placeholder = '/{id}'

# Phase 2 — Managed API sync
[managed]
poll_interval_minutes  = 10
fetch_concurrency      = 5
dns_cache_ttl_minutes  = 5

# Phase 3 — Comparison
[comparison]
freshness_threshold_multiplier = 3   # Phase 3 needs Phase 2 success within
                                     # 3 * managed.poll_interval

# Topology — used by the Phase 2 deployment-aware resolver.
[deployment.topology]
k8s_nodes     = [
    { ip = "10.50.1.10", default_namespace = "techmart" },
]
legacy_chosts = ["10.50.1.11"]

# Per-API namespace overrides (rare). Each is one entry.
# [[deployment.topology.namespace_overrides]]
# api_id    = "<apim-uuid>"
# namespace = "techmart-experimental"

[bff]
listen_addr           = "0.0.0.0:8443"
tls_cert              = "/etc/ads/certs/server.crt"
tls_key               = "/etc/ads/certs/server.key"
verify_client_cert    = false   # bearer token auth, not mTLS
read_timeout_seconds  = 30
write_timeout_seconds = 30

[bff.token_cache]
ttl_seconds  = 30
max_entries  = 1000

[health]
listen_addr = "0.0.0.0:9090"   # separate port from BFF for K8s probes

# Multi-replica K8s leader election. Set enabled = true and supply
# namespace + pod_name (typically via the downward API in the Deployment).
[k8s]
enabled   = false
namespace = ""
pod_name  = ""

[retention]
classifications_retention_days = 90
discovered_apis_retention_days = 30
