# GitHub Actions workflow template. To enable CI on this repo:
#   1. mv this file to .github/workflows/ci.yml
#   2. (one-time, if using gh CLI) `gh auth refresh -s workflow`
#   3. git add .github/workflows/ci.yml && git commit && git push
#
# Lives outside .github/workflows/ here only because the initial push
# happened with an OAuth token lacking the workflow scope.

name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  test:
    runs-on: ubuntu-latest
    services:
      postgres:
        image: postgres:15
        env:
          POSTGRES_PASSWORD: testpw
          POSTGRES_DB: ads_test
        ports:
          - 5432:5432
        options: >-
          --health-cmd pg_isready
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: '1.22'
          cache: true
      - name: Download deps
        run: go mod download
      - name: Lint
        run: |
          go vet ./...
          gofmt -l . | tee /dev/stderr | (! read)
      - name: Unit tests (race)
        run: go test -race -short ./internal/...
        env:
          ADS_DB_URL: postgres://postgres:testpw@localhost:5432/ads_test?sslmode=disable

  build:
    runs-on: ubuntu-latest
    needs: test
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-go@v5
        with:
          go-version: '1.22'
          cache: true
      - name: Build
        run: make build
      - uses: actions/upload-artifact@v4
        with:
          name: ads-binary
          path: bin/ads
          if-no-files-found: error

  docker:
    runs-on: ubuntu-latest
    needs: build
    if: github.event_name == 'push' && github.ref == 'refs/heads/main'
    steps:
      - uses: actions/checkout@v4
      - uses: docker/setup-buildx-action@v3
      - name: Build image
        uses: docker/build-push-action@v5
        with:
          context: .
          file: deploy/docker/Dockerfile
          push: false
          tags: ghcr.io/kidhurshan/wso2-api-discovery-server:dev
          build-args: |
            VERSION=dev
            COMMIT=${{ github.sha }}
