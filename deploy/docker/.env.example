# Copy to .env and fill in. Never commit .env.

# Bundled-mode: random 256-bit password the compose stack will use for both
# the postgres container and ADS. Generate with: openssl rand -hex 32
ADS_DB_PASSWORD=

# WSO2 APIM service-account password (for Publisher REST sync).
APIM_SVC_PASSWORD=

# WSO2 APIM introspect basic-auth header value: base64(client_id:client_secret).
# Get the client_id/secret from APIM's Dynamic Client Registration endpoint.
APIM_INTROSPECT_BASIC_AUTH=

# Optional: shared bearer token for the BFF if not using OAuth2 introspection.
ADS_BFF_BEARER_TOKEN=

# Override the ADS image (defaults to ghcr.io/Kidhurshan/wso2-api-discovery-server:1.0.0).
# ADS_IMAGE=ghcr.io/Kidhurshan/wso2-api-discovery-server:1.0.0

# Host-side port overrides (useful when 8443 / 9090 are already taken).
# ADS_BFF_HOST_PORT=8443
# ADS_HEALTH_HOST_PORT=9090

# External-mode only (used with docker-compose.external.yml).
# ADS_DB_HOST=postgres.example.internal
# ADS_DB_PORT=5432
