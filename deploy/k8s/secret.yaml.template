# Secret template — copy to secret.yaml, fill in real values, kubectl
# apply, and DO NOT check the populated copy into git.
#
# All values must be base64-encoded. Use:
#   echo -n 'mypassword' | base64

apiVersion: v1
kind: Secret
metadata:
  name: ads-secrets
  namespace: governance
type: Opaque
data:
  db_password:              REPLACE_WITH_BASE64
  apim_svc_password:        REPLACE_WITH_BASE64
  apim_introspect_basic:    REPLACE_WITH_BASE64
  deepflow_ch_password:     REPLACE_WITH_BASE64
