# Build output
bin/
*.exe
*.so

# Local config (never push real configs with secrets)
config/config.toml
config/config.toml.local
.env
.env.local
deploy/docker/.env
deploy/docker/config.toml
deploy/docker/certs/

# Helm subchart download artifacts (Chart.lock IS pushed; charts/ is built
# locally via `helm dependency update`).
deploy/helm/*/charts/
deploy/helm/*/charts/*.tgz

# Test output (keep test/results/ pushed; only local-prefixed scratch is excluded)
test/results/local-*

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store

# Spec files and Claude Code entry point — local only, never pushed.
claude/
CLAUDE.md

# Claude Code working directory (settings, history) — never pushed.
.claude/

# Logs
*.log
